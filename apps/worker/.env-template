# Database
DATABASE_PRIMARY_POOLER_URL=

# Supabase (for storage and auth)
SUPABASE_URL=
# OR
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Redis Queue (for BullMQ job processing)
# In production, uses Railway internal Redis (redis://...railway.internal:6379)
REDIS_QUEUE_URL=redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Slack Integration (for Slack file processing)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_STATE_SECRET=
SLACK_OAUTH_REDIRECT_URL=http://localhost:3003/apps/slack/oauth-callback

# LLMs (for document processing)
OPENAI_API_KEY=

# Google AI (for document tag embeddings)
GOOGLE_GENERATIVE_AI_API_KEY=

# Email (Resend - for notifications)
RESEND_API_KEY=

# Banking Providers
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=sandbox
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
ENABLEBANKING_APPLICATION_ID=
ENABLE_BANKING_KEY_CONTENT=
ENABLEBANKING_REDIRECT_URL=
TELLER_CERT_BASE64=
TELLER_KEY_BASE64=

# R2 Storage (institution logos)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Logo.dev (fallback logos for institutions)
LOGO_DEV_TOKEN=

# Environment
NODE_ENV=development
WORKER_ENV=development
MIDDAY_ENCRYPTION_KEY=

# Railway (set automatically in production)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_REPLICA_REGION=europe-west4-drams3a

# Optional: Health check board
BOARD_USERNAME=
BOARD_PASSWORD=

# Optional: Server port
PORT=8080

# Digipoort/SBR WUS
# Development defaults to dry-run unless DIGIPOORT_DRY_RUN=false.
DIGIPOORT_MODE=dry-run
DIGIPOORT_DRY_RUN=true
# Shared endpoint or operation-specific endpoint. Use the current WUS v1.2
# endpoint from the Aansluit Suite Digipoort service description.
DIGIPOORT_WUS_ENDPOINT_URL=
DIGIPOORT_SOAP_VERSION=1.1
DIGIPOORT_TIMEOUT_MS=30000
# mTLS client certificate. Use either PFX or cert+key.
DIGIPOORT_PFX_PATH=
DIGIPOORT_PFX_BASE64=
DIGIPOORT_CERT_PASSPHRASE=
DIGIPOORT_CERT_PATH=
DIGIPOORT_CERT_BASE64=
DIGIPOORT_KEY_PATH=
DIGIPOORT_KEY_BASE64=
DIGIPOORT_CA_PATH=
DIGIPOORT_CA_BASE64=
# Intermediary identifiers used by XML templates.
DIGIPOORT_INTERMEDIAIR_OIN=
DIGIPOORT_INTERMEDIAIR_RSIN=
DIGIPOORT_INTERMEDIAIR_KVK=
DIGIPOORT_INTERMEDIAIR_NAME=
# Operation-specific SOAP actions and XML body templates.
DIGIPOORT_REQUEST_MANDATE_SOAP_ACTION=
DIGIPOORT_REQUEST_MANDATE_BODY_TEMPLATE_PATH=
DIGIPOORT_ACTIVATE_MANDATE_SOAP_ACTION=
DIGIPOORT_ACTIVATE_MANDATE_BODY_TEMPLATE_PATH=
DIGIPOORT_FETCH_SERVICE_MESSAGES_SOAP_ACTION=
DIGIPOORT_FETCH_SERVICE_MESSAGES_BODY_TEMPLATE_PATH=
DIGIPOORT_SUBMIT_RETURN_SOAP_ACTION=
DIGIPOORT_SUBMIT_RETURN_BODY_TEMPLATE_PATH=
# Optional: full envelope/security header templates when WUS message-level
# signing is handled outside this process.
DIGIPOORT_WUS_SECURITY_HEADER_TEMPLATE_PATH=

# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Mistral
MISTRAL_API_KEY=

# Xero
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here
XERO_OAUTH_REDIRECT_URL=http://localhost:3003/apps/xero/oauth-callback

# QuickBooks
QUICKBOOKS_CLIENT_ID=your_client_id
QUICKBOOKS_CLIENT_SECRET=your_client_secret
QUICKBOOKS_OAUTH_REDIRECT_URL=http://localhost:3003/apps/quickbooks/oauth-callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Fortnox
FORTNOX_CLIENT_ID=your_client_id_here
FORTNOX_CLIENT_SECRET=your_client_secret_here
FORTNOX_OAUTH_REDIRECT_URL=http://localhost:3003/apps/fortnox/oauth-callback




# Invoice
INVOICE_JWT_SECRET=

# Exa
EXA_API_KEY=

# CompanyEnrich (customer enrichment)
COMPANY_ENRICH_API_KEY=

# Insights (set to "true" to enable weekly insight generation + emails)
INSIGHTS_ENABLED=false

SENDBLUE_FROM_NUMBER=
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
